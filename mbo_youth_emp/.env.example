# Copy this file to `.env` and fill in real values.
# .env is git-ignored; .env.example is committed as documentation.

# ──────────────── Django ────────────────
# Optional overrides. Defaults live in config/settings.py.
# PORTAL_URL is the frontend base used in emails and redirects.
PORTAL_URL=http://localhost:3000

# ──────────────── Database (PostgreSQL) ────────────────
DB_NAME=mbo_portal_v2
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ──────────────── Cloudinary (media storage) ────────────────
# Stores uploaded passports, certificates, and application documents.
# Find these on your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────── Brevo (transactional email) ────────────────
# Get an API key from https://app.brevo.com/settings/keys/api
# The sender email must be a verified sender in your Brevo account.
# Set BREVO_MOCK_MODE=False to send real emails.
BREVO_MOCK_MODE=True
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=Mbo Youth Empowerment

# ──────────────── Paystack (payments) ────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developers
# Set PAYSTACK_MOCK_MODE=False to hit the live API.
PAYSTACK_MOCK_MODE=True
PAYSTACK_SECRET_KEY=

# ──────────────── Celery (background tasks) ────────────────
# Broker URL for Redis. CELERY_TASK_ALWAYS_EAGER=True runs tasks
# synchronously in-process (no broker/worker needed) — handy for local dev.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# ──────────────── OTP behaviour ────────────────
# How long a code is valid for after it is issued.
OTP_TTL_SECONDS=600
# How many failed verify attempts before the active code is invalidated.
OTP_MAX_ATTEMPTS=5
# How long the client must wait between /otp/send/ or /otp/resend/ calls.
OTP_RESEND_COOLDOWN_SECONDS=60
